# Database — Postgres (docker-compose default: assistai:assistai_password@localhost:5433/assistai_db)
DATABASE_URL=postgresql://assistai:assistai_password@localhost:5433/assistai_db
SQL_ECHO=false

# OpenAI
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
ENCRYPTION_KEY=
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/spreadsheets

# Google Sheets — ID from spreadsheet URL (docs.google.com/spreadsheets/d/{ID}/edit)
GOOGLE_SHEET_ID=

# App
APP_NAME=AssistAI
APP_VERSION=1.0.0
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_WINDOW_WIDTH=1200
APP_WINDOW_HEIGHT=800
APP_THEME=light
APP_AUTO_SAVE=true